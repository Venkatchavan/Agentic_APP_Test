# Environment variables for local development.
# Copy to .env and fill in real values.

# ── App ──────────────────────────────────────────────
DEBUG=true
APP_NAME="Agentic Productivity API"

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_app

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

# ── Gmail OAuth ──────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Outlook OAuth ────────────────────────────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ── AI Layer ─────────────────────────────────────────
# Provider options: openai | anthropic | gemini
AI_PROVIDER=gemini
AI_GEMINI_API_KEY=          # Free tier at aistudio.google.com
AI_GEMINI_MODEL=gemini-2.0-flash
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_BUDGET_LIMIT_USD=50.0

# ── S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=agentic-app-artifacts
